# -----------------------------------------------------------------------------
# AskGovRAGBot Environment Variables Template
# Copy this file to '.env' and fill in your keys.
# -----------------------------------------------------------------------------

# FastAPI Server Port
PORT=8000
HOST=0.0.0.0

# Serve static frontend files from FastAPI when true
SERVE_FRONTEND=true

# Active Vector Database: "chroma" (local SQLite) or "pinecone" (cloud)
VECTOR_STORE=chroma

# Active LLM Provider: "gemini" or "openai" or "nebius"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash

# Active Embedding Provider: "cohere", "openai", or "local"
# Keep this aligned with the embeddings used to seed the active vector DB.
EMBEDDING_PROVIDER=cohere

# -----------------------------------------------------------------------------
# API Keys (Provide keys for the services you plan to enable)
# -----------------------------------------------------------------------------

# Google Gemini API Key (Required if LLM_PROVIDER=gemini)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (Required if LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here

# Cohere API Key (Required if EMBEDDING_PROVIDER=cohere)
COHERE_API_KEY=your_cohere_api_key_here

# Pinecone Credentials (Required if VECTOR_STORE=pinecone)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=askgovragbot-index

# LangSmith Observability Tracing (Set to true to trace executions in LangSmith)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY or LANGCHAIN_API_KEY is required for LangSmith tracing
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=AskGovRAGBot
